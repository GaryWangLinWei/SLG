    "@types/koa-static": "^4.0.2",
    "@types/node": "^20.0.0",
    "jest": "^29.5.0",
    "nodemon": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "@koa/cors": "^4.0.0",
