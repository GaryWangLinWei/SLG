{
  "name": "rok-automation",
  "version": "1.1.0",
  "description": "万国觉醒自动化助手",
  "main": "dist/electron/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "npm run server",
    "server": "ts-node server/index.ts",
    "server:dev": "nodemon --watch 'server/**/*.ts' --exec 'ts-node' server/index.ts",
    "test": "jest",
    "lint": "eslint src/**/*.ts",
    "electron:dev": "concurrently \"cd web && npm run dev\" \"wait-on http://localhost:5173 && tsc && electron .\"",
    "electron:build": "cd web && npm run build && cd .. && tsc && node -e \"const f=require('fs');f.cpSync('assets','dist/assets',{recursive:true});f.cpSync('plugins/rok/templates','dist/plugins/rok/templates',{recursive:true});f.cpSync('plugins/rok/models','dist/plugins/rok/models',{recursive:true})\" && electron-builder",
    "electron:build:win": "cd web && npm run build && cd .. && tsc && node -e \"const f=require('fs');f.cpSync('assets/vcredist','node_modules/onnxruntime-node/bin/napi-v6/win32/x64',{recursive:true});f.cpSync('assets','dist/assets',{recursive:true});f.cpSync('plugins/rok/templates','dist/plugins/rok/templates',{recursive:true});f.cpSync('plugins/rok/models','dist/plugins/rok/models',{recursive:true})\" && electron-builder --win",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.rok.automation",
    "productName": "ROK助手",
    "releaseInfo": {
      "releaseNotes": "1.1.0更新内容\n1. 宝石坐标识别改回Tesseract OCR，解决模板匹配截断识别导致的重复采集问题。\n2. 科技研究支持多尺度模板匹配，解决滑动后图标缩放导致的识别不稳定问题。\n3. 山洞探索状态持久化，循环间不再重复探索已探索山洞。\n4. 城寨图标遮挡自动避让，缩放点击点被遮挡时自动滑动避让。\n5. 修复迷雾探索/世界喊话开启时，自动攻打城寨仍可勾选的互斥逻辑问题。\n6. 倒计时解析移除h/m/s格式支持，只识别冒号格式，避免空闲状态误判。"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "web/dist/**/*",
      "node_modules/**/*",
      "!node_modules/onnxruntime-node/bin/napi-v6/darwin/**/*",
      "!node_modules/onnxruntime-node/bin/napi-v6/linux/**/*",
      "!node_modules/onnxruntime-node/bin/napi-v6/*/*.tar.gz",
      "package.json"
    ],
    "asarUnpack": [
      "node_modules/onnxruntime-node/**/*",
      "node_modules/@img/**/*"
    ],
    "extraResources": [
      {
        "from": "tools/platform-tools/platform-tools",
        "to": "adb",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "plugins/rok/templates",
        "to": "templates"
      },
      {
        "from": "traineddata",
        "to": "traineddata"
      },
      {
        "from": "plugins/rok/models",
        "to": "models"
      }
    ],
    "compression": "maximum",
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "electron/installer.nsh"
    },
    "publish": {
      "provider": "generic",
      "url": "http://106.15.11.158:3456/updates"
    }
  },
  "keywords": [
    "slg",
    "automation",
    "opencv",
    "adb"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/koa": "^2.13.0",
    "@types/koa__cors": "^5.0.1",
    "@types/koa-bodyparser": "^4.3.0",
    "@types/koa-router": "^7.4.0",
    "@types/koa-static": "^4.0.2",
    "@types/node": "^20.0.0",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.1",
    "electron-builder": "^26.8.1",
    "electron-is-dev": "^3.0.1",
    "jest": "^29.5.0",
    "nodemon": "^3.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "@koa/cors": "^4.0.0",
    "electron-updater": "^6.8.3",
    "koa": "^2.14.0",
    "koa-bodyparser": "^4.4.0",
    "koa-router": "^12.0.0",
    "koa-static": "^5.0.0",
    "onnxruntime-node": "^1.26.0",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0"
  }
}
